# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: For server-side operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# MAIL SERVER CONFIGURATION (Agent Mail)
# ============================================

# Your own mail server (Stalwart, Mailcow, etc.)
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false

# OR use a relay service like Brevo (recommended for deliverability)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-email
# SMTP_PASS=your-brevo-api-key

# Mail encryption key (for storing user credentials)
# Generate with: openssl rand -base64 32
MAIL_ENCRYPTION_KEY=your-encryption-key

# ============================================
# MAIL SERVER CONFIGURATION (For auto-provisioning)
# ============================================

# Mail domain for agent emails
MAIL_DOMAIN=agent-mail.online
NEXT_PUBLIC_MAIL_DOMAIN=agent-mail.online

# Optional: External API to create mailboxes
# If not set, mailboxes should be created manually on the server
# MAIL_SERVER_API_URL=https://your-mail-server/api/mailbox
# MAIL_SERVER_API_KEY=your-api-key

# Alternative: You can run a simple API on your mail server
# that accepts POST requests to create mailboxes via ./setup.sh
